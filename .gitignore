# IDE
.idea/

# Private (backup-tool)
scripts/backup-tool/backup.conf
scripts/backup-tool/backup.conf.bak
scripts/backup-tool/backup.toml

# Python の再生成物 (uv の仮想環境・bytecode・各種ツールキャッシュ)
# ツールごとにパスを列挙するとツール追加時の追記漏れで生成物が tracked になるため、
# パターンで畳んで場所に依存させない。
**/.venv/
**/__pycache__/
**/.ruff_cache/
**/.mypy_cache/
**/.pytest_cache/
**/.coverage

# Logs
*.log

# Claude
**/.claude/settings.local.json
**/.claude/plans/

# Private (defense-in-depth: 実体は $HOME 側だが repo への誤コミット防止)
**/.gitconfig.private
*.env

# 一時作業ファイル (scratch)
.cache/
tmp/
