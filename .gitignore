scripts/node-security-notifier/.venv/
scripts/node-security-notifier/**/__pycache__/
scripts/node-security-notifier/.ruff_cache/
scripts/node-security-notifier/.mypy_cache/
scripts/node-security-notifier/.pytest_cache/
scripts/node-security-notifier/.coverage

