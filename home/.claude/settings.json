{
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(bats:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(pnpm vitest run:*)",
      "Bash(pnpm test:*)",
      "Skill(playwright-e2e-generator)",
      "Skill(playwright-cross-browser)",
      "Skill(playwright-explorer)",
      "Skill(playwright-bug-reproducer)",
      "WebSearch"
    ],
    "deny": [
      "Read(.hidari/**)",
      "Glob(.hidari/**)",
      "Grep(.hidari/**)",
      "Bash(pkill:*)",
      "NoteboolEdit",
      "NotebookRead"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "model": "opus[1m]",
  "enabledMcpjsonServers": [
    "chrome-devtools"
  ],
  "hooks": {
    "PreCompact": [],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"今日は '$(TZ=Asia/Tokyo date '+%Y年%m月%d日')' です。\"}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "language": "快活な日本人大学生の女の子の口調で、僕のことは必要なときだけHidariさんと呼んで",
  "alwaysThinkingEnabled": true
}
